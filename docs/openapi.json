  "components": {
    "schemas": {
      "ApiResponse": {
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "success",
              "fail",
              "error"
            ]
          },
          "data": {
            "type": "object",
            "description": "Response data"
          },
          "message": {
            "type": "string",
            "description": "Error message"
          },
          "timestamp": {
            "type": "integer",
            "description": "Unix timestamp"
          }
        },
        "type": "object"
      },
      "MqttCommand": {
        "type": "object",
        "description": "MQTT JSON command (send to command topic)",
        "properties": {
          "command": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high",
              "timer1",
              "timer2",
              "timer3",
              "away",
              "cook30",
              "cook60",
              "autonight",
              "clearqueue"
            ]
          },
          "speed": {
            "type": "integer",
            "minimum": 0,
            "maximum": 255
          },
          "timer": {
            "type": "integer",
            "minimum": 0,
            "maximum": 65535
          },
          "vremotecmd": {
            "type": "string"
          },
          "vremoteindex": {
            "type": "integer"
          },
          "vremotename": {
            "type": "string"
          },
          "rfremotecmd": {
            "type": "string"
          },
          "rfremoteindex": {
            "type": "integer"
          },
          "percentage": {
            "type": "integer",
            "description": "Fan speed as percentage (0-100)"
          },
          "fandemand": {
            "type": "integer",
            "description": "Ventilation demand (0-200)"
          },
          "rfco2": {
            "type": "integer",
            "description": "CO2 ppm"
          },
          "rfdemand": {
            "type": "integer",
            "description": "Ventilation demand 0-200"
          },
          "rfzone": {
            "type": "integer",
            "description": "Zone for rfdemand"
          },
          "dtype": {
            "type": "string",
            "description": "Domoticz device type"
          }
        }
      },
      "CommandRequest": {
        "type": "object",
        "description": "Fan command or speed/timer",
        "properties": {
          "command": {
            "type": "string",
            "description": "Named command",
            "enum": [
              "low",
              "medium",
              "high",
              "timer1",
              "timer2",
              "timer3",
              "away",
              "cook30",
              "cook60",
              "autonight",
              "clearqueue"
            ]
          },
          "speed": {
            "type": "integer",
            "description": "Fan speed",
            "minimum": 0,
            "maximum": 255
          },
          "timer": {
            "type": "integer",
            "description": "Timer in minutes",
            "minimum": 0,
            "maximum": 65535
          },
          "percentage": {
            "type": "integer",
            "description": "Fan speed as percentage (0-100)",
            "minimum": 0,
            "maximum": 100
          },
          "fandemand": {
            "type": "integer",
            "description": "Ventilation demand (0-200, 0=0% 200=100%)",
            "minimum": 0,
            "maximum": 200
          }
        }
      },
      "VRemoteRequest": {
        "type": "object",
        "description": "Virtual remote command",
        "properties": {
          "command": {
            "type": "string",
            "description": "Command name",
            "enum": [
              "away",
              "low",
              "medium",
              "high",
              "timer1",
              "timer2",
              "timer3",
              "join",
              "leave",
              "auto",
              "autonight",
              "cook30",
              "cook60"
            ]
          },
          "index": {
            "type": "integer",
            "description": "Virtual remote index",
            "minimum": 0,
            "maximum": 11
          },
          "name": {
            "type": "string",
            "description": "Virtual remote name (alternative to index)"
          }
        }
      },
      "RFRemoteRequest": {
        "type": "object",
        "description": "RF remote command",
        "properties": {
          "command": {
            "type": "string",
            "description": "RF command name",
            "enum": [
              "away",
              "low",
              "medium",
              "high",
              "timer1",
              "timer2",
              "timer3",
              "join",
              "leave",
              "auto",
              "autonight",
              "cook30",
              "cook60",
              "motion_on",
              "motion_off"
            ]
          },
          "index": {
            "type": "integer",
            "description": "RF remote index",
            "minimum": 0,
            "maximum": 11
          }
        }
      },
      "RFCO2Request": {
        "type": "object",
        "description": "Send CO2 value via RF",
        "properties": {
          "co2": {
            "type": "integer",
            "description": "CO2 level in ppm",
            "minimum": 0,
            "maximum": 10000
          },
          "index": {
            "type": "integer",
            "description": "RF remote index (default 0)",
            "minimum": 0,
            "maximum": 11
          }
        }
      },
      "RFDemandRequest": {
        "type": "object",
        "description": "Send ventilation demand via RF",
        "properties": {
          "demand": {
            "type": "integer",
            "description": "Demand level (0=0%, 200=100%)",
            "minimum": 0,
            "maximum": 200
          },
          "zone": {
            "type": "integer",
            "description": "Zone (default 0)",
            "minimum": 0,
            "maximum": 255
          },
          "index": {
            "type": "integer",
            "description": "RF remote index (default 0)",
            "minimum": 0,
            "maximum": 11
          }
        }
      },
      "RFConfigRequest": {
        "type": "object",
        "description": "Configure RF remote settings",
        "properties": {
          "index": {
            "type": "integer",
            "description": "RF remote index",
            "minimum": 0,
            "maximum": 11
          },
          "setting": {
            "type": "string",
            "description": "Setting name (setrfdevicesourceid/setrfdevicedestid/setrfdevicebidirectional)"
          },
          "value": {
            "type": "string",
            "description": "Setting value (hex ID like 96,C8,B6 or true/false)"
          }
        }
      },
      "DebugRequest": {
        "type": "object",
        "description": "Debug/reboot actions",
        "properties": {
          "action": {
            "type": "string",
            "description": "Action (reboot/level0/level1/level2/level3)"
          }
        }
      },
      "OutsideTempRequest": {
        "type": "object",
        "description": "Set outside temperature",
        "properties": {
          "temp": {
            "type": "number",
            "description": "Temperature in Celsius (-100 to 100)"
          }
        }
      },
      "SetSettingRequest": {
        "type": "object",
        "description": "Write Itho device setting",
        "properties": {
          "index": {
            "type": "integer",
            "description": "Setting index",
            "minimum": 0,
            "maximum": 255
          },
          "value": {
            "type": "number",
            "description": "New value (int or float, must be within setting min/max)"
          }
        }
      },
      "ManualControlRequest": {
        "type": "object",
        "description": "WPU manual control (4030 command)",
        "properties": {
          "index": {
            "type": "integer",
            "description": "Manual operation index (e.g. 0=outside temp, 20=pump speed)"
          },
          "datatype": {
            "type": "integer",
            "description": "Data type (uint8)"
          },
          "value": {
            "type": "integer",
            "description": "Value (uint16)"
          },
          "checked": {
            "type": "integer",
            "description": "Checked flag (uint8)"
          }
        }
      }
    }
  }
}