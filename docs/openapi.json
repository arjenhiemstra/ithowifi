                }
              }
            }
          }
        },
        "parameters": [
          {
            "name": "name",
            "in": "query",
            "description": "Filter by source name",
            "schema": {
              "type": "string"
            }
          }
        ]
      }
    },
    "/api/v2/settings": {
      "get": {
        "summary": "Read Itho setting by index",
        "tags": [
          "REST API v2"
        ],
        "responses": {
          "200": {
            "description": "JSend success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          }
        },
        "parameters": [
          {
            "name": "index",
            "in": "query",
            "description": "Setting index",
            "schema": {
              "type": "integer",
              "minimum": 0,
              "maximum": 255
            }
          }
        ]
      },
      "put": {
        "summary": "Write Itho setting",
        "tags": [
          "REST API v2"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SetSettingRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "JSend success"
          },
          "400": {
            "description": "JSend fail"
          },
          "403": {
            "description": "Settings API disabled"
          }
        }
      }
    },
    "/api/v2/command": {
      "post": {
        "summary": "Send fan command",
        "tags": [
